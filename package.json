{
  "name": "retroix",
  "version": "1.2.2",
  "description": "A tiny, dependency-free retro arcade game engine: DPI-aware canvas, render-safe game loop, keyboard/mouse/touch input, Supabase-or-localStorage leaderboard, overlay screens with retro high-score entry, and drawing helpers.",
  "main": "retroix.js",
  "module": "retroix.js",
  "browser": "retroix.js",
  "unpkg": "retroix.js",
  "jsdelivr": "retroix.js",
  "type": "commonjs",
  "files": [
    "retroix.js",
    "retroix.min.js",
    "retroix.css",
    "retroix.min.css",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./retroix.js",
    "./retroix.css": "./retroix.css",
    "./css": "./retroix.css"
  },
  "scripts": {
    "minify": "npx --yes esbuild retroix.js --minify --outfile=retroix.min.js && npx --yes esbuild retroix.css --minify --outfile=retroix.min.css",
    "test": "node -e \"require('./retroix.js'); console.log('retroix loads OK')\""
  },
  "keywords": [
    "game-engine",
    "retro",
    "arcade",
    "canvas",
    "vanilla-javascript",
    "no-build",
    "leaderboard",
    "html5-game",
    "gamedev"
  ],
  "author": "DanMat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanMat/Retroix.git"
  },
  "bugs": {
    "url": "https://github.com/DanMat/Retroix/issues"
  },
  "homepage": "https://danmat.github.io/Retroix/",
  "sideEffects": [
    "retroix.css"
  ]
}
